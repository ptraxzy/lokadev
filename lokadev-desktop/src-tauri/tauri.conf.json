{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "LokaDev",
  "version": "1.0.4",
  "identifier": "dev.lokadev.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LokaDev",
        "width": 1080,
        "height": 700,
        "minWidth": 880,
        "minHeight": 580,
        "resizable": true,
        "decorations": false,
        "center": true,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Next-generation local development environment",
    "longDescription": "LokaDev lets you run multiple isolated projects simultaneously with their own web servers, databases, and runtime versions — without Docker.",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "libayatana-appindicator-gtk3"]
      }
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
